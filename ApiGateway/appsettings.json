{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "courseRestRoute": {
        "ClusterId": "courseCluster",
        "Match": { "Path": "/api/courses/{**catch-all}" }
      },
      "courseGrpcRoute": {
        "ClusterId": "courseCluster",
        "Match": { "Path": "/course.Course/{**catch-all}" }
      },
      "authRestRoute": {
        "ClusterId": "authCluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "profileRestRoute": {
        "ClusterId": "authCluster",
        "Match": { "Path": "/api/profile/{**catch-all}" }
      },
      "authGrpcRoute": {
        "ClusterId": "authCluster",
        "Match": { "Path": "/auth.Auth/{**catch-all}" }
      },
      "taskRestRoute": {
        "ClusterId": "taskCluster",
        "Match": {
          "Path": "/api/tasks/{**catch-all}"
        }
      },
      "taskGrpcRoute": {
        "ClusterId": "taskCluster",
        "Match": {
          "Path": "/task.Task/{**catch-all}"
        }
      },
      "fileRestRoute": {
        "ClusterId": "fileCluster",
        "Match": {
          "Path": "/api/files/{**catch-all}"
        }
      },
      "fileGrpcRoute": {
        "ClusterId": "fileCluster",
        "Match": {
          "Path": "/file.File/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "authServiceNode": {
            "Address": "http://gnosix_auth_api:80"
          }
        }
      },
      "courseCluster": {
        "Destinations": {
          "courseServiceNode": {
            "Address": "http://gnosix_course_api:80"
          }
        }
      },
      "taskCluster": {
        "Destinations": {
          "taskServiceNode": {
            "Address": "http://gnosix_task_api:80"
          }
        }
      },
      "fileCluster": {
        "Destinations": {
          "fileServiceNode": {
            "Address": "http://gnosix_file_api:80"
          }
        }
      }
    }
  }
}